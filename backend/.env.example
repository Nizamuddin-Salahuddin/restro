# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (Railway/Neon PostgreSQL)
# Get this URL from your database provider
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secret (Generate a random string - use: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Razorpay Configuration (Get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Frontend URL (for CORS - your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Optional: SMS Provider for OTP (Enable when needed)
# SMS_PROVIDER=msg91
# MSG91_AUTH_KEY=your_msg91_auth_key
# MSG91_SENDER_ID=your_sender_id
